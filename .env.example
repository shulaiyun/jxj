# ============================================================
# NextGen Panel — 环境变量配置文件
# 复制此文件为 .env 并填入真实值，不要提交 .env 到 Git
# ============================================================

# 数据库配置
DB_USER=nextgen
DB_PASSWORD=nextgen_db_pass_change_me
DB_DATABASE=nextgen_panel
DB_ROOT_PASSWORD=nextgen_root_change_me

# JWT 密钥（生产环境必须换成随机长字符串）
SECRET_KEY=PLEASE_CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET

# 面板配置
PANEL_NAME=NextGen Panel
PANEL_DOMAIN=your-domain.com   # 例：vpn.example.com

# EPay 支付（易支付/第三方免签）
# 在 EPay 后台获取以下信息
EPAY_API_URL=https://your-epay.com
EPAY_PID=your_pid_here
EPAY_KEY=your_payment_key_here
